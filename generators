import random
import string

# Ваши данные для генерации уникального email
FIRST_NAME = "nikolay"
LAST_NAME = "kuznetsov"
COHORT = "46"
DOMAIN = "@yandex.ru"

def generate_unique_email():
    """Генерирует email в формате: имя_фамилия_когорта_3случайныецифры@домен"""
    random_digits = ''.join(random.choices(string.digits, k=3))
    email = f"{FIRST_NAME}_{LAST_NAME}_{COHORT}_{random_digits}{DOMAIN}"
    return email.lower()

def generate_valid_password():
    """Генерирует пароль длиной не менее 6 символов (обычно 6-10 символов)"""
    length = random.randint(6, 10)
    letters = string.ascii_letters + string.digits
    return ''.join(random.choices(letters, k=length))

def generate_invalid_password():
    """Генерирует пароль менее 6 символов (для проверки ошибки)"""
    length = random.randint(1, 5)
    letters = string.ascii_letters + string.digits
    return ''.join(random.choices(letters, k=length))
